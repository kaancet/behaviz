   "source": [
    "x = np.linspace(0, 10, 80)\n",
    "y = np.sin(x)\n",
    "z = np.cos(x)\n",
    "\n",
    "with bv.canvas(save=\"fig.pdf\") as ax:\n",
    "    bv.plot_line(x,y,color=\"#787878\")\n",
    "    bv.plot_scatter(x,z,color=\"#991122\")"
